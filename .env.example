# Provider API keys are entered by users at runtime in the browser.
# They are stored only in React state / sessionStorage unless a scheduled job is created.

# Required for Supabase-backed workflow features.
# Core agent runs work without these values.
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
